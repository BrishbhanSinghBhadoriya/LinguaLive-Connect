# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/Lingulive?retryWrites=true&w=majority

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: https://lingua-live.vercel.app
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app
