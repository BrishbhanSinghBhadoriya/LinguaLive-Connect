# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/Lingulive?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret_string

# ── API Server (Railway backend URL — set this in Vercel dashboard) ───────────
# Used in production so the frontend knows where to connect for WebSocket/API
# Example: https://lingua-live-api.up.railway.app
API_SERVER_URL=https://your-railway-app.up.railway.app

# ── Public vars (exposed to browser) ─────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=LinguaLive AI
