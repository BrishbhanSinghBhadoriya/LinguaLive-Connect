{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev --prefix artifacts/lingua-live-next",
    "dev:api": "npm run dev --prefix artifacts/api-server",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "install:all": "npm install --prefix artifacts/api-server && npm install --prefix artifacts/lingua-live-next",
    "build": "npm run build --prefix artifacts/lingua-live-next",
    "typecheck": "npm run typecheck --prefix artifacts/lingua-live-next"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
